{
  "name": "portfolio-qa",
  "version": "1.0.0",
  "private": true,
  "description": "QA Automation Engineer Portfolio Platform",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter frontend dev --filter backend start:dev",
